<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/navigation"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.ubayadev.pejuangsubuh.view.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login">

        <action
            android:id="@+id/actionLoginFragment"
            app:destination="@id/dashboardFragment" />

    </fragment>

    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.ubayadev.pejuangsubuh.view.DashboardFragment"
        android:label="Dashboard"
        tools:layout="@layout/fragment_dashboard">

        <action
            android:id="@+id/actionDashboardFragment"
            app:destination="@id/newHabitFragment" />

        <action
            android:id="@+id/actionDashboardEditFragment"
            app:destination="@id/editHabitFragment" />

    </fragment>

    <fragment
        android:id="@+id/newHabitFragment"
        android:name="com.ubayadev.pejuangsubuh.view.NewHabitFragment"
        android:label="New Habit"
        tools:layout="@layout/fragment_new_habit" />

    <fragment
        android:id="@+id/editHabitFragment"
        android:name="com.ubayadev.pejuangsubuh.view.EditHabitFragment"
        android:label="Edit Habit"
        tools:layout="@layout/fragment_edit_habit">

        <argument
            android:name="habitId"
            app:argType="integer"
            android:defaultValue="0" />

    </fragment>

</navigation>