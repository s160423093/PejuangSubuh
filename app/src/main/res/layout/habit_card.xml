<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <variable
            name="habit"
            type="com.ubayadev.pejuangsubuh.model.Habit" />
        <variable
            name="listener"
            type="com.ubayadev.pejuangsubuh.view.HabitItemListener" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="25dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:tag="@{habit.id}">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/imgIcon"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:background="@drawable/ic_textfield_background"
                        android:contentDescription="icon"
                        android:padding="5dp"
                        android:src="@drawable/ic_default_foreground"
                        tools:ignore="HardcodedText" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/txtName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@{habit.name}"
                            android:textColor="@color/black"
                            android:textStyle="bold"
                            android:tag="@{habit.id}"
                            android:onClick="@{listener::onClick}" />

                        <TextView
                            android:id="@+id/txtDescription"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@{habit.description}"
                            android:textSize="12sp" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/txtStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:background="@drawable/ic_textfield_background"
                        android:gravity="center"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:text='@{habit.progress >= habit.goal ? "Done" : "In Progress"}'
                        android:textColor="@color/black" />
                </LinearLayout>


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal">


                    <TextView
                        android:id="@+id/textView1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Progress"
                        android:textColor="@color/black"
                        tools:ignore="HardcodedText" />

                    <TextView
                        android:id="@+id/txtGoalUnit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@{habit.progress + `/` + habit.goal + ` ` + habit.unit}"
                        android:textStyle="bold" />

                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progressBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="5dp"
                    android:layout_marginTop="5dp"
                    android:max="@{habit.goal}"
                    android:progress="@{habit.progress}"
                    android:progressTint="@color/purple" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal">

                    <ImageButton
                        android:id="@+id/btnEdit"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:backgroundTint="@color/gray"
                        android:contentDescription="decrease"
                        android:onClick="@{listener::onClick}"
                        android:src="@drawable/ic_edit"
                        android:tag="@{habit.id}"
                        app:tint="@color/black"
                        tools:ignore="HardcodedText" />

                    <Space
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1" />

                    <ImageButton
                        android:id="@+id/btnDecrease"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:backgroundTint="@color/gray"
                        android:contentDescription="decrease"
                        android:onClick="@{() -> listener.onDecrease(habit)}"
                        android:src="@drawable/ic_remove"
                        app:tint="@color/black"
                        tools:ignore="HardcodedText" />

                    <ImageButton
                        android:id="@+id/btnIncrease"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:backgroundTint="@color/purple"
                        android:contentDescription="increase"
                        android:onClick="@{() -> listener.onIncrease(habit)}"
                        android:src="@drawable/ic_add"
                        app:tint="@color/white"
                        tools:ignore="HardcodedText" />

                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>